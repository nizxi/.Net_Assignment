<Window x:Class="AppointmentSystem.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AppointmentSystem"
        xmlns:views="clr-namespace:AppointmentSystem.Views"
        xmlns:vm="clr-namespace:AppointmentSystem.ViewModels"
        mc:Ignorable="d"
        Title="{Binding ApplicationTitle}" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Background="{StaticResource PrimaryBrush}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                <TextBlock Text="🏥" FontSize="32" Margin="0,0,15,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Hospital Appointment System" Foreground="White" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Version}" Foreground="#E0E0E0" FontSize="10"/>
                </StackPanel>
            </StackPanel>

            <!-- Navigation Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                <Button Command="{Binding NavigateToAppointmentsCommand}" 
                        Style="{StaticResource ButtonStyle}"
                        Background="{StaticResource SecondaryBrush}"
                        Margin="0,0,10,0" Padding="15,8">
                    View Appointments
                </Button>
                <Button Command="{Binding NavigateToBookAppointmentCommand}" 
                        Style="{StaticResource ButtonStyle}"
                        Background="{StaticResource AccentBrush}"
                        Margin="0,0,10,0" Padding="15,8">
                    Book Appointment
                </Button>
                <Button Command="{Binding NavigateToDoctorsCommand}" 
                        Style="{StaticResource ButtonStyle}"
                        Background="{StaticResource SecondaryBrush}"
                        Padding="15,8">
                    Doctor Management
                </Button>
            </StackPanel>
        </Grid>

        <!-- Content Area -->
        <ContentControl Grid.Row="1" Content="{Binding CurrentViewModel}">
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type vm:AppointmentViewModel}">
                    <views:AppointmentView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:DoctorViewModel}">
                    <views:DoctorView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:BookAppointmentViewModel}">
                    <views:BookAppointmentView/>
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>

        <!-- Footer -->
        <Grid Grid.Row="2" Background="{StaticResource SecondaryBrush}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                <TextBlock Text="© 2024 Hospital Appointment System. All rights reserved." Foreground="White" FontSize="11"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
